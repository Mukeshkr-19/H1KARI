# ============================================
# HIKARI v2.0 - Environment Variables
# ============================================
# Copy this file to .env and fill in your API keys
# NEVER commit your .env file to version control!

# --- AI Provider Keys (at least ONE required) ---

# OmniRoute local gateway (preferred when configured)
# Run OmniRoute separately, create a local API key in its UI, and keep the
# endpoint bound to loopback. Set a separate exact image-capable model or combo
# to enable explicit Cloud Vision requests; text aliases are never reused.
OMNIROUTE_API_KEY=
OMNIROUTE_BASE_URL=http://127.0.0.1:20128/v1
OMNIROUTE_FAST_MODEL=auto/fast
OMNIROUTE_BALANCED_MODEL=auto/chat
OMNIROUTE_SMART_MODEL=auto/smart
OMNIROUTE_VISION_MODEL=

# 9Router local gateway (optional fallback)
# Run it on a different port when OmniRoute is also running. The default model
# assumes a combo named "free-forever" exists in your local 9Router setup.
NINEROUTER_API_KEY=
NINEROUTER_BASE_URL=http://127.0.0.1:20129/v1
NINEROUTER_FAST_MODEL=free-forever
NINEROUTER_BALANCED_MODEL=free-forever
NINEROUTER_SMART_MODEL=free-forever
NINEROUTER_VISION_MODEL=

# Optional offline Apple-Silicon vision description model. Both values must be
# explicit absolute local paths. HIKARI never downloads model files at runtime.
HIKARI_VISION_MODEL_DIR=
HIKARI_VISION_MANIFEST_PATH=

# Google AI Studio (RECOMMENDED - best free tier, 1M context)
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_AI_STUDIO_KEY=

# Groq (RECOMMENDED - fastest inference, 300+ tokens/sec)
# Get key: https://console.groq.com/keys
GROQ_API_KEY=

# OpenRouter (model variety, free tier models)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Cerebras (ultra-fast inference)
# Get key: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# NVIDIA NIM (frontier models)
# Get key: https://build.nvidia.com/
NVIDIA_API_KEY=

# Cohere (fallback, RAG)
# Get key: https://dashboard.cohere.com/
COHERE_API_KEY=

# --- Skills ---

# Weather (OpenWeatherMap)
# Get key: https://openweathermap.org/api
WEATHER_API_KEY=

# News (optional - uses BBC RSS by default, no key needed)
# NEWS_API_KEY=

# --- Voice companion (optional UI layer; off by default) ---

# Set to 1 to emit companion_update WebSocket events for voice turns
# HIKARI_VOICE_COMPANION=1
# Spoken output defaults to a comfortable 185 words per minute. Valid range:
# 120-220. Pocket TTS is an optional free/local backend installed separately.
# HIKARI_TTS_RATE=185
# HIKARI_TTS_BACKEND=macos-say
# HIKARI_TTS_VOICE=Samantha

# Frontend build: NEXT_PUBLIC_HIKARI_VOICE_COMPANION=1 in hikari-frontend/.env.local

# --- Security ---

# Codename for voice fallback activation
# Choose your own private value. Never commit your real codename.
CODENAME=change-me
